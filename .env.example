# Copy this file to .env.local and fill in the values.
# Find these in Supabase Dashboard → Project Settings → API Keys.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. Bypasses RLS. Never expose to the browser.
# Prefer the new sb_secret_* key (rotatable independently of the JWT secret).
SUPABASE_SECRET_KEY=sb_secret_your-secret-key
# Legacy JWT-based service role key. Kept as a fallback during migration.
# Once SUPABASE_SECRET_KEY is verified in prod, this can be removed.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Whop payment integration
# Get these from https://whop.com/dashboard → Developer settings
WHOP_API_KEY=whop_api_xxxxxxxxxx
WHOP_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Product IDs — create products on Whop dashboard, copy IDs here
WHOP_STARTER_PRODUCT_ID=prod_xxxxxxxxxx
WHOP_STANDARD_PRODUCT_ID=prod_xxxxxxxxxx
WHOP_PLUS_PRODUCT_ID=prod_xxxxxxxxxx

# Checkout link URLs — create checkout links on Whop dashboard
NEXT_PUBLIC_WHOP_STARTER_CHECKOUT=https://whop.com/checkout/plan_xxxxxxxxxx
NEXT_PUBLIC_WHOP_STANDARD_CHECKOUT=https://whop.com/checkout/plan_xxxxxxxxxx

# Resend transactional email (welcome emails, invites, announcements)
RESEND_API_KEY=re_xxxxxxxxxx
# Optional: verified sender. Defaults to onboarding@resend.dev (test only).
RESEND_FROM_EMAIL=SchoolPurse <noreply@schoolpurse.app>
NEXT_PUBLIC_APP_URL=https://schoolpurse.app
