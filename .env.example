# Copy this file to .env.local and fill in the values.
# Find these in Supabase Dashboard → Project Settings → API Keys.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. Bypasses RLS. Never expose to the browser.
# Prefer the new sb_secret_* key (rotatable independently of the JWT secret).
SUPABASE_SECRET_KEY=sb_secret_your-secret-key
# Legacy JWT-based service role key. Kept as a fallback during migration.
# Once SUPABASE_SECRET_KEY is verified in prod, this can be removed.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Whop payment integration
# Get these from https://whop.com/dashboard → Developer settings
WHOP_API_KEY=whop_api_xxxxxxxxxx
WHOP_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Product IDs — create a "Pro" and an "AI" product on Whop, copy IDs here.
# These map a paid Whop product to the schools.plan tier (pro / ai) that every
# feature gate reads. Must be set or payments won't unlock features.
WHOP_PRO_PRODUCT_ID=prod_xxxxxxxxxx
WHOP_AI_PRODUCT_ID=prod_xxxxxxxxxx

# Checkout link URLs — create checkout links on Whop dashboard. The pricing
# page + onboarding buttons link here; without them the buttons fall back to
# /login. Starter = $35/mo (50 students), Pro = $50/mo (250). AI is custom-
# priced (contact us) so it has no checkout link.
NEXT_PUBLIC_WHOP_STARTER_CHECKOUT=https://whop.com/checkout/plan_xxxxxxxxxx
NEXT_PUBLIC_WHOP_PRO_CHECKOUT=https://whop.com/checkout/plan_xxxxxxxxxx

# AI dashboard chat (AI plan). Server-only — never expose to the browser.
# Get a key at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx
# Optional model override. Defaults to claude-haiku-4-5 (cheapest, fits the AI
# plan's per-query budget). Set to claude-opus-4-8 for maximum answer quality.
# SCHOOLPURSE_AI_MODEL=claude-haiku-4-5

# WhatsApp outbound (AI plan) — parent fee reminders + school-notice fan-out.
# Provider-agnostic. Leave WHATSAPP_PROVIDER unset to store messages without
# sending (recorded as "skipped"). Set "meta" or "twilio" + the matching block
# to actually deliver. Server-only — never expose to the browser.
# WHATSAPP_PROVIDER=meta
#   Meta WhatsApp Cloud API:
# WHATSAPP_META_TOKEN=EAAG...
# WHATSAPP_META_PHONE_ID=1234567890
#   Twilio WhatsApp (alternative):
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_WHATSAPP_FROM=+14155238886

# PostHog product analytics (who signs up + activity). Public, client-side.
# Create a project at posthog.com, copy its Project API key. Without this,
# analytics no-ops. Host defaults to US cloud; set for EU/self-hosted.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend transactional email (welcome emails, invites, announcements)
RESEND_API_KEY=re_xxxxxxxxxx
# Optional: verified sender. Defaults to onboarding@resend.dev (test only).
RESEND_FROM_EMAIL=SchoolPurse <noreply@schoolpurse.app>
NEXT_PUBLIC_APP_URL=https://schoolpurse.app

# Subdomain split (optional). Put the dashboard on a subdomain, landing on the
# apex. BOTH unset by default = single-domain behaviour (no change). To enable:
#   1. Add the domain in Vercel + a DNS CNAME (app -> cname.vercel-dns.com).
#   2. Set both vars below and redeploy.
# NEXT_PUBLIC_DASHBOARD_HOST=app.schoolpurse.app
# AUTH_COOKIE_DOMAIN=.schoolpurse.app   # leading dot — spans apex + subdomain
